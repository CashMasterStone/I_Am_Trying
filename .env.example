# Environment Variables Template
# Author: Cyrus Makai Schoonover
# Repository: https://github.com/CashMasterStone/I_Am_Trying
# 
# Copy this to .env and fill in your actual values
# NEVER commit .env to git - it's in .gitignore

# Flask Secret Key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=

# Authorized Web3 Wallet Address (Born2Sub.x)
AUTHORIZED_WALLET=

# GitHub Personal Access Token (for API operations)
GITHUB_TOKEN=

# Optional: Ngrok Auth Token (for secure tunneling on public WiFi)
NGROK_AUTH_TOKEN=

# Optional: Admin Password (for basic auth fallback)
ADMIN_PASSWORD=

# Session Configuration
SESSION_TIMEOUT=3600
MAX_UPLOAD_SIZE=104857600

# Network Security
ALLOWED_ORIGINS=https://born2sub.x,http://localhost:8000
CORS_ENABLED=true

# Logging
LOG_LEVEL=INFO
AUDIT_LOG_FILE=./logs/audit.log
